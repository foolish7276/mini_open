# Model settings
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0
MODEL_BASE_URL=
MODEL_API_KEY=

# Provider keys (optional fallback if MODEL_API_KEY is empty)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Runtime paths
PROJECT_ROOT=.
SESSIONS_DIR=.sessions
MEMORY_DIR=.memory

# Context / scheduler
MAX_CONTEXT_CHARS=50000
CONTEXT_WINDOW_TOKENS=24000
MAX_CONCURRENT_RUNS=4
MAX_SUBAGENT_DEPTH=1

# Heartbeat
HEARTBEAT_MINUTES=30
